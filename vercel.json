{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "site/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/updates",
      "dest": "/api/updates.py"
    },
    {
      "src": "/api/viewers",
      "dest": "/api/viewer.py"
    },
    {
      "src": "/api/history",
      "dest": "/api/history.py"
    },
    {
      "src": "/(.*)",
      "dest": "/site/$1"
    },
    {
      "src": "/",
      "dest": "/site/index.html"
    }
  ]
}