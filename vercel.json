{
  "version": 2,
  "functions": {
    "api/*.py": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "5 * * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/cron",
      "dest": "/api/cron.py"
    },
    {
      "src": "/api/updates",
      "dest": "/api/updates.py"
    },
    {
      "src": "/api/viewers",
      "dest": "/api/viewer.py"
    },
    {
      "src": "/api/history",
      "dest": "/api/history.py"
    },
    {
      "src": "/(.*)",
      "dest": "/site/$1"
    },
    {
      "src": "/",
      "dest": "/site/index.html"
    }
  ]
}
